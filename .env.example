# ===========================================
# ENVIRONMENT TEMPLATE
# Copy this file to .env.develop / .env.staging / .env.production
# and fill in the real values.
# ===========================================

APP_NAME=EIR
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=eir
DB_USERNAME=
DB_PASSWORD=

JWT_SECRET=
JWT_EXPIRATION=3600

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

CACHE_DRIVER=file
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DOCKER_PHP_VERSION=8.3
DOCKER_PGSQL_VERSION=16
DOCKER_MYSQL_VERSION=8.0
DOCKER_NGINX_PORT=8080
